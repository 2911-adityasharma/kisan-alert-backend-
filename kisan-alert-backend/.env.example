# ============================================================
# Kisan-Alert Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with actual secrets!
# ============================================================

# ── Supabase (Database & Auth) ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ── Google Gemini (AI / Advisory Generation) ─────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Twilio (WhatsApp Notifications) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── AgroMonitoring (Weather & Soil Data) ─────────────────────
AGROMONITORING_API_KEY=your-agromonitoring-api-key
AGROMONITORING_POLYGON_ID=your-polygon-id

# ── Firebase (Push Notifications) ────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json

# ── Alert Thresholds ────────────────────────────────────────
# Rainfall (mm) at or below which a low-rain alert is triggered
LOW_RAIN_THRESHOLD_MM=2.0
